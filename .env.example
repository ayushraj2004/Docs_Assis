# Copy this file to .env and fill in your API keys
# At least one LLM provider is required

# Option 1: Groq (Free, Fast - Recommended)
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Option 2: OpenAI
# Get your key at: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# LLM Provider: "groq" or "openai" (default: groq)
LLM_PROVIDER=groq

# Groq model (default: llama3-70b-8192)
GROQ_MODEL=llama3-70b-8192

# OpenAI model (default: gpt-3.5-turbo)
OPENAI_MODEL=gpt-3.5-turbo

# Flask secret key (change this in production)
SECRET_KEY=your-secret-key-change-in-production

# Upload folder (default: uploads)
UPLOAD_FOLDER=uploads

# FAISS index folder (default: faiss_store)
FAISS_FOLDER=faiss_store

# Max file size in MB (default: 50)
MAX_FILE_SIZE_MB=50
